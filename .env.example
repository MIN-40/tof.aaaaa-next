# tof.aaaaa environment variables

# AWS S3 / CloudFront
# 실제 운영에서는 S3 원본 주소보다 CloudFront 주소 사용 추천
NEXT_PUBLIC_ASSET_BASE_URL=https://your-cloudfront-domain.cloudfront.net

# Mux
NEXT_PUBLIC_MUX_PLAYBACK_DOMAIN=https://stream.mux.com
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret

# Supabase, 선택사항
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Sheets 주문 저장용 Apps Script
NEXT_PUBLIC_GOOGLE_SHEET_WEB_APP_URL=https://script.google.com/macros/s/your-id/exec
